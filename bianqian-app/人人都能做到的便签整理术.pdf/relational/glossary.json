      "aliases": [],
      "related_terms": [
        "阿娜吉备忘录整理法",
        "可视化",
        "细分化",
        "一元化"
      ]
    },
    {
      "term": "可视化",
      "definition": "便签整理法的三大技巧之一，指把时间和脑子里的想法写在便签或备忘录上，使其一目了然，从而掌握零碎时间和待办事项。",
      "labels": [
        "整理收纳",
        "整理方法",
        "便签整理法",
        "可视化"
      ],
      "source_chunks": [
        "6f9718b0_e170115d-6260-4b43-bf80-fc16e7a96a2d.sk, 1lib.sk, z-lib.sk)_chunk_001"
      ],
      "source_chunk": "",
      "aliases": [],
      "related_terms": [
        "细分化",
        "一元化",
        "时间轴"
      ]
    },
    {
      "term": "细分化",
      "definition": "便签整理法的三大技巧之一，指将笼统模糊的整理目标不断细分，直到变成具体可行、能立即动手的小任务，写在便签上以便执行。",
      "labels": [
        "整理收纳",
        "整理方法",
        "便签整理法",
        "细分化"
      ],
      "source_chunks": [
        "6f9718b0_e170115d-6260-4b43-bf80-fc16e7a96a2d.sk, 1lib.sk, z-lib.sk)_chunk_001"
      ],
      "source_chunk": "",
      "aliases": [],
      "related_terms": [
        "妖怪便签",
        "可视化",
        "一元化"
      ]
    },
    {
      "term": "一元化",
      "definition": "便签整理法的三大技巧之一，指把重要的信息、笔记、待办事项全部汇集到备忘录里，避免信息分散导致遗漏或错误。",
      "labels": [
        "整理收纳",
        "整理方法",
        "便签整理法",
        "一元化"
      ],
      "source_chunks": [
        "6f9718b0_e170115d-6260-4b43-bf80-fc16e7a96a2d.sk, 1lib.sk, z-lib.sk)_chunk_001"
      ],
