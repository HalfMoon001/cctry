  "entries": [
    {
      "term": "便签整理法",
      "definition": "一种利用便签和备忘录进行时间管理和物品整理的方法，通过可视化、细分化、一元化三大技巧解决整理难题。",
      "labels": [
        "整理收纳",
        "整理方法",
        "便签整理法"
      ],
      "source_chunks": [
        "6f9718b0_e170115d-6260-4b43-bf80-fc16e7a96a2d.sk, 1lib.sk, z-lib.sk)_chunk_001"
      ],
