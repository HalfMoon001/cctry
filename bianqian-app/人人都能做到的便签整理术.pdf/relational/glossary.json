      "aliases": [],
      "related_terms": [
        "可视化",
        "细分化",
        "备忘录"
      ]
    },
    {
      "term": "妖怪便签",
      "definition": "指那些作业量非常大、无法判断完成时间、让人没干劲儿看着就头疼的便签（如“整理储藏室”），容易导致拖延。",
      "labels": [
        "整理收纳",
        "常见问题",
        "妖怪便签"
